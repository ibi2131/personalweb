<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IBR∆HIM</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Syne:wght@300;400;600;800&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #010610;
  --blue: #1a4fff;
  --blue2: #4488ff;
  --blue3: #0a2299;
  --glow: #1a4fff66;
  --text: #c8d8ff;
  --muted: #4466aa;
  --accent: #7ab3ff;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Syne', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}
canvas#stars { position: fixed; top: 0; left: 0; z-index: 0; pointer-events: none; }
.scanline {
  position: fixed; inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,40,255,0.012) 3px, rgba(0,40,255,0.012) 4px);
  pointer-events: none; z-index: 1;
}
.noise {
  position: fixed; inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 1;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.2rem 3rem;
  background: linear-gradient(to bottom, rgba(1,6,16,0.95), transparent);
  backdrop-filter: blur(10px);
}
.nav-logo {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900; font-size: 1.1rem;
  color: #fff;
  text-shadow: 0 0 20px var(--blue);
  letter-spacing: 0.2rem;
}
.nav-links { display: flex; gap: 1rem; }
.nav-btn {
  background: transparent;
  border: 1px solid var(--blue);
  color: var(--accent);
  font-family: 'Orbitron', sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.2rem;
  padding: 0.55rem 1.4rem;
  cursor: pointer;
  transition: all 0.3s;
  text-transform: uppercase;
  position: relative;
  overflow: hidden;
}
.nav-btn::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--blue);
  transform: translateX(-100%);
  transition: transform 0.3s;
  z-index: -1;
}
.nav-btn:hover::before { transform: translateX(0); }
.nav-btn:hover { color: #fff; box-shadow: 0 0 20px var(--glow); }
.nav-btn.active { background: var(--blue); color: #fff; }

/* PAGES */
.page { display: none; position: relative; z-index: 10; }
.page.active { display: block; }

/* HOME PAGE */
#home {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 6rem 2rem 4rem;
  text-align: center;
}
.hero-tag {
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem;
  color: var(--blue2);
  letter-spacing: 0.3rem;
  margin-bottom: 1.5rem;
  animation: fadeUp 0.8s ease both;
}
.hero-name {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(3rem, 10vw, 6rem);
  font-weight: 900;
  color: #fff;
  text-shadow: 0 0 40px var(--blue), 0 0 80px var(--blue3);
  line-height: 1;
  animation: fadeUp 0.8s 0.1s ease both;
  position: relative;
}
.hero-name .glitch-text {
  position: relative;
  display: inline-block;
  animation: glitch 6s infinite;
}
@keyframes glitch {
  0%, 92%, 100% { text-shadow: 0 0 40px var(--blue), 0 0 80px var(--blue3); transform: translate(0); }
  93% { text-shadow: -3px 0 #ff003c, 3px 0 var(--blue2); transform: translate(-3px,0); }
  94% { text-shadow: 3px 0 #ff003c, -3px 0 var(--blue2); transform: translate(3px,0); }
  95% { text-shadow: 0 0 40px var(--blue); transform: translate(0); }
}
.hero-sub {
  font-size: 1rem;
  color: var(--muted);
  margin-top: 1rem;
  letter-spacing: 0.15rem;
  animation: fadeUp 0.8s 0.2s ease both;
}
.hero-divider {
  width: 200px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--blue2), transparent);
  margin: 2.5rem auto;
  animation: fadeUp 0.8s 0.3s ease both;
}

/* ACHIEVEMENTS */
.achievements-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.65rem;
  color: var(--blue2);
  letter-spacing: 0.4rem;
  margin-bottom: 2rem;
  animation: fadeUp 0.8s 0.4s ease both;
}
.achievements-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  max-width: 680px;
  width: 100%;
  animation: fadeUp 0.8s 0.5s ease both;
}
.ach-card {
  display: flex; align-items: center; gap: 1.5rem;
  background: linear-gradient(135deg, rgba(26,79,255,0.06), rgba(10,34,153,0.04));
  border: 1px solid rgba(26,79,255,0.15);
  padding: 1.1rem 1.6rem;
  border-radius: 2px;
  text-align: left;
  transition: all 0.4s;
  position: relative;
  overflow: hidden;
}
.ach-card::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--blue), transparent);
  transition: width 0.4s;
}
.ach-card:hover { border-color: rgba(26,79,255,0.4); box-shadow: 0 0 30px rgba(26,79,255,0.1); transform: translateX(4px); }
.ach-card:hover::before { width: 3px; }
.ach-icon { font-size: 1.6rem; min-width: 2.5rem; text-align: center; }
.ach-content { flex: 1; }
.ach-label {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.6rem;
  color: var(--blue2);
  letter-spacing: 0.2rem;
  margin-bottom: 0.2rem;
}
.ach-text { font-size: 1rem; color: var(--accent); font-weight: 600; }
.ach-sub { font-size: 0.78rem; color: var(--muted); margin-top: 0.15rem; font-family: 'Space Mono', monospace; }

/* SOCIAL SECTION */
.social-section {
  margin-top: 3rem;
  animation: fadeUp 0.8s 0.6s ease both;
}
.social-label {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.6rem;
  color: var(--muted);
  letter-spacing: 0.3rem;
  margin-bottom: 1rem;
}
.yt-btn {
  display: inline-flex; align-items: center; gap: 0.8rem;
  background: rgba(255,30,30,0.08);
  border: 1px solid rgba(255,30,30,0.3);
  color: #ff6666;
  padding: 0.9rem 2rem;
  font-family: 'Orbitron', sans-serif;
  font-size: 0.7rem;
  letter-spacing: 0.15rem;
  text-decoration: none;
  transition: all 0.3s;
  border-radius: 2px;
}
.yt-btn:hover { background: rgba(255,30,30,0.15); box-shadow: 0 0 25px rgba(255,30,30,0.2); transform: translateY(-2px); }
.yt-icon { font-size: 1.2rem; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

/* LOGIN MODAL */
.modal-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 200;
  background: rgba(1,6,16,0.85);
  backdrop-filter: blur(12px);
  align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: linear-gradient(135deg, #050d1f, #0a1530);
  border: 1px solid rgba(26,79,255,0.3);
  padding: 3rem;
  max-width: 420px; width: 90%;
  position: relative;
  box-shadow: 0 0 80px rgba(26,79,255,0.15);
  animation: modalIn 0.4s cubic-bezier(0.16,1,0.3,1) both;
}
@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
.modal::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--blue2), transparent);
}
.modal-close {
  position: absolute; top: 1rem; right: 1.2rem;
  background: none; border: none; color: var(--muted);
  font-size: 1.2rem; cursor: pointer; transition: color 0.2s;
}
.modal-close:hover { color: #fff; }
.modal-tag {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: var(--blue2);
  letter-spacing: 0.3rem;
  margin-bottom: 1rem;
}
.modal-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.3rem;
  font-weight: 900;
  color: #fff;
  margin-bottom: 0.5rem;
}
.modal-sub { font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; line-height: 1.6; }
.code-input-wrap { position: relative; margin-bottom: 1rem; }
.code-input {
  width: 100%;
  background: rgba(26,79,255,0.06);
  border: 1px solid rgba(26,79,255,0.25);
  color: var(--accent);
  font-family: 'Space Mono', monospace;
  font-size: 1rem;
  padding: 1rem 1.2rem;
  outline: none;
  transition: all 0.3s;
  letter-spacing: 0.1rem;
}
.code-input:focus { border-color: var(--blue2); box-shadow: 0 0 20px rgba(26,79,255,0.15); }
.code-input::placeholder { color: rgba(68,102,170,0.5); font-size: 0.85rem; letter-spacing: 0.05rem; }
.enter-btn {
  width: 100%;
  background: var(--blue);
  border: none;
  color: #fff;
  font-family: 'Orbitron', sans-serif;
  font-size: 0.7rem;
  letter-spacing: 0.2rem;
  padding: 1rem;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.enter-btn::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  transform: translateX(-100%);
  transition: transform 0.5s;
}
.enter-btn:hover::before { transform: translateX(100%); }
.enter-btn:hover { background: var(--blue2); box-shadow: 0 0 30px var(--glow); }
.error-msg {
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem;
  color: #ff4466;
  margin-top: 0.75rem;
  display: none;
  text-align: center;
  letter-spacing: 0.1rem;
}
.error-msg.show { display: block; animation: shake 0.4s ease; }
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8px); }
  75% { transform: translateX(8px); }
}

/* FRIEND PAGES */
#friend-page {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 6rem 2rem;
  text-align: center;
}
.friend-back {
  position: absolute; top: 5.5rem; left: 2rem;
  background: none;
  border: 1px solid rgba(26,79,255,0.3);
  color: var(--muted);
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.15rem;
  padding: 0.5rem 1rem;
  cursor: pointer;
  transition: all 0.3s;
  z-index: 50;
}
.friend-back:hover { color: var(--accent); border-color: var(--blue2); }
.friend-greeting {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  color: var(--blue2);
  letter-spacing: 0.3rem;
  margin-bottom: 1.5rem;
  animation: fadeUp 0.6s ease both;
}
.friend-msg {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.5rem, 5vw, 3rem);
  font-weight: 900;
  color: #fff;
  text-shadow: 0 0 40px var(--blue), 0 0 80px var(--blue3);
  max-width: 700px;
  line-height: 1.3;
  animation: fadeUp 0.6s 0.1s ease both;
}
.friend-line {
  width: 160px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--blue2), transparent);
  margin: 2rem auto;
  animation: fadeUp 0.6s 0.2s ease both;
}
.friend-sub {
  font-size: 0.85rem;
  color: var(--muted);
  font-family: 'Space Mono', monospace;
  animation: fadeUp 0.6s 0.3s ease both;
  letter-spacing: 0.1rem;
}
.friend-orb {
  width: 180px; height: 180px; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(26,79,255,0.3), rgba(0,0,40,0.1));
  box-shadow: 0 0 60px rgba(26,79,255,0.4), 0 0 120px rgba(26,79,255,0.15);
  margin: 2.5rem auto;
  animation: fadeUp 0.6s 0.15s ease both, orbPulse 4s ease-in-out infinite;
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem;
}
@keyframes orbPulse {
  0%, 100% { transform: translateY(0); box-shadow: 0 0 60px rgba(26,79,255,0.4), 0 0 120px rgba(26,79,255,0.15); }
  50% { transform: translateY(-12px); box-shadow: 0 20px 80px rgba(26,79,255,0.3), 0 0 150px rgba(26,79,255,0.2); }
}

/* FLOATING PARTICLES */
.particle {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 2;
  animation: particleFloat linear infinite;
}
@keyframes particleFloat {
  0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(-100px) rotate(360deg); opacity: 0; }
}
</style>
</head>
<body>
<canvas id="stars"></canvas>
<div class="scanline"></div>
<div class="noise"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">IBR∆HIM</div>
  <div class="nav-links">
    <button class="nav-btn active" onclick="showHome()">HOME</button>
    <button class="nav-btn" onclick="openLogin()">LOGIN</button>
  </div>
</nav>

<!-- HOME PAGE -->
<div id="home" class="page active">
  <div class="hero-tag">// WELCOME TO THE ARCHIVE</div>
  <div class="hero-name"><span class="glitch-text">IBRAHIM'S WEBSITE</span></div>
  <div class="hero-sub">The one & only. Documented for the record.</div>
  <div class="hero-divider"></div>

  <div class="achievements-title">// VERIFIED ACHIEVEMENTS</div>
  <div class="achievements-grid">
    <div class="ach-card">
      <div class="ach-icon">🥊</div>
      <div class="ach-content">
        <div class="ach-label">COMBAT SPORTS</div>
        <div class="ach-text">3x UFC World Champion</div>
        <div class="ach-sub">They retired the belt after him</div>
      </div>
    </div>
    <div class="ach-card">
      <div class="ach-icon">🇺🇸</div>
      <div class="ach-content">
        <div class="ach-label">POLITICAL OFFICE</div>
        <div class="ach-text">2 Years as President of the United States</div>
        <div class="ach-sub">Served with unmatched distinction</div>
      </div>
    </div>
    <div class="ach-card">
      <div class="ach-icon">☪️</div>
      <div class="ach-content">
        <div class="ach-label">INCOMING</div>
        <div class="ach-text">Next Supreme Leader of Iran</div>
