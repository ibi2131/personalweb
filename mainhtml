      <div class="ach-content">
        <div class="ach-label">CONTENT CREATION</div>
        <div class="ach-text">100 Million YouTube Subscribers</div>
        <div class="ach-sub">ibi2131 — the algorithm bows to him</div>
      </div>
    </div>
    <div class="ach-card">
      <div class="ach-icon">📚</div>
      <div class="ach-content">
        <div class="ach-label">ACADEMICS</div>
        <div class="ach-text">10 A*s & 2 Distinctions — IGCSEs</div>
        <div class="ach-sub">While everyone else was struggling</div>
      </div>
    </div>
  </div>

  <div class="social-section">
    <div class="social-label">// FIND ME</div>
    <a href="https://youtube.com/@ibi2131" target="_blank" class="yt-btn">
      <span class="yt-icon">▶</span> YOUTUBE — @ibi2131
    </a>
  </div>
</div>

<!-- FRIEND PAGE -->
<div id="friend-page" class="page">
  <button class="friend-back" onclick="showHome()">← BACK</button>
  <div class="friend-greeting">// PERSONAL MESSAGE</div>
  <div class="friend-orb" id="friend-orb">👋</div>
  <div class="friend-msg" id="friend-msg"></div>
  <div class="friend-line"></div>
  <div class="friend-sub">— Ibrahim</div>
</div>

<!-- LOGIN MODAL -->
<div class="modal-overlay" id="loginModal">
  <div class="modal">
    <button class="modal-close" onclick="closeLogin()">✕</button>
    <div class="modal-tag">// SECURE ACCESS</div>
    <div class="modal-title">Enter Your Code</div>
    <div class="modal-sub">Ibrahim gave you a personal code. Enter it below to access your private page.</div>
    <div class="code-input-wrap">
      <input class="code-input" id="codeInput" type="text" placeholder="enter code here..." autocomplete="off" />
    </div>
    <button class="enter-btn" onclick="submitCode()">ENTER →</button>
    <div class="error-msg" id="errorMsg">⚠ Invalid code. Try again.</div>
  </div>
</div>

<script>
// ── STAR CANVAS ──────────────────────────────────────
const canvas = document.getElementById('stars');
const ctx = canvas.getContext('2d');
function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
resizeCanvas();
window.addEventListener('resize', resizeCanvas);
const stars = Array.from({length: 160}, () => ({
  x: Math.random()*window.innerWidth, y: Math.random()*window.innerHeight,
  r: Math.random()*1.2+0.1, a: Math.random()*0.6+0.1,
  dx: (Math.random()-0.5)*0.15, dy: (Math.random()-0.5)*0.15
}));
function drawStars() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  stars.forEach(s => {
    ctx.beginPath(); ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(100,160,255,${s.a})`; ctx.fill();
    s.x+=s.dx; s.y+=s.dy;
    if(s.x<0||s.x>canvas.width)s.dx*=-1;
    if(s.y<0||s.y>canvas.height)s.dy*=-1;
  });
  requestAnimationFrame(drawStars);
}
drawStars();

// ── FLOATING PARTICLES ───────────────────────────────
function spawnParticle() {
  const p = document.createElement('div');
  p.className = 'particle';
  const size = Math.random()*3+1;
  p.style.cssText = `
    width:${size}px; height:${size}px;
    left:${Math.random()*100}vw;
    background:rgba(${Math.random()>0.5?'100,160,255':'30,79,255'},${Math.random()*0.4+0.1});
    animation-duration:${Math.random()*15+10}s;
    animation-delay:${Math.random()*5}s;
  `;
  document.body.appendChild(p);
  setTimeout(() => p.remove(), 25000);
}
setInterval(spawnParticle, 600);

// ── CODES ────────────────────────────────────────────
const codes = {
  'shahwaiz67': { msg: 'Kaisa hai shahwaiz kaaluuu', emoji: '😂' },
  'shayan67':   { msg: 'Shani tidday kulfi wallay paper ki tayyari kar', emoji: '📝' },
  'areesha67':  { msg: 'Areesha dumbass', emoji: '💀' },
  'nadir67':    { msg: 'Hello nadir bhai', emoji: '🤝' },
};

// ── NAV / PAGE LOGIC ─────────────────────────────────
function showHome() {
  document.getElementById('home').classList.add('active');
  document.getElementById('friend-page').classList.remove('active');
  document.querySelector('.nav-btn.active')?.classList.remove('active');
  document.querySelectorAll('.nav-btn')[0].classList.add('active');
}

function showFriendPage(data) {
  document.getElementById('friend-msg').textContent = data.msg;
  document.getElementById('friend-orb').textContent = data.emoji;
  document.getElementById('home').classList.remove('active');
  document.getElementById('friend-page').classList.add('active');
}

// ── LOGIN ────────────────────────────────────────────
function openLogin() {
  document.getElementById('loginModal').classList.add('open');
  setTimeout(() => document.getElementById('codeInput').focus(), 300);
}
function closeLogin() {
  document.getElementById('loginModal').classList.remove('open');
  document.getElementById('codeInput').value = '';
  document.getElementById('errorMsg').classList.remove('show');
}
function submitCode() {
  const val = document.getElementById('codeInput').value.trim().toLowerCase();
  if (codes[val]) {
    closeLogin();
    showFriendPage(codes[val]);
  } else {
    const err = document.getElementById('errorMsg');
    err.classList.remove('show');
    void err.offsetWidth;
    err.classList.add('show');
  }
}
document.getElementById('codeInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitCode();
});
document.getElementById('loginModal').addEventListener('click', e => {
  if (e.target === document.getElementById('loginModal')) closeLogin();
});
</script>
</body>
